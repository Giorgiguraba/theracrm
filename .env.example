# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New (2025+) naming. Legacy NEXT_PUBLIC_SUPABASE_ANON_KEY is also accepted.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Drizzle direct connection (use the pooler-bypass / direct conn string from Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Brevo (email) — Phase 3
BREVO_API_KEY=
EMAIL_FROM=hello@yourdomain.ge

# Meta Lead Ads — Phase 2
META_APP_SECRET=
META_VERIFY_TOKEN=set-any-random-string

# Public site URL (for callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
